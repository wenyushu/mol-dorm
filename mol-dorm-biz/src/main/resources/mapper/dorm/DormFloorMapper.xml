<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mol.dorm.biz.mapper.DormFloorMapper">

    <resultMap id="BaseResultMap" type="com.mol.dorm.biz.entity.DormFloor">
        <id column="id" property="id" />
        <result column="building_id" property="buildingId" />
        <result column="floor_num" property="floorNum" />
        <result column="gender_limit" property="genderLimit" />
        <result column="status" property="status" />
        <result column="version" property="version" />
        <result column="del_flag" property="delFlag" />
    </resultMap>

    <select id="selectActiveFloors" resultMap="BaseResultMap">
        SELECT f.* FROM dorm_floor f
                            INNER JOIN dorm_building b ON f.building_id = b.id
        WHERE f.building_id = #{buildingId}
          AND f.status = 20
          AND b.status = 20
          AND f.del_flag = '0'
          AND b.del_flag = '0'
        ORDER BY f.floor_num ASC
    </select>
</mapper>