<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mol.dorm.biz.mapper.DormBedMapper">

    <resultMap id="BaseResultMap" type="com.mol.dorm.biz.entity.DormBed">
        <id column="id" property="id" />
        <result column="campus_id" property="campusId" />
        <result column="building_id" property="buildingId" />
        <result column="floor_id" property="floorId" />
        <result column="room_id" property="roomId" />
        <result column="bed_label" property="bedLabel" />
        <result column="sort_order" property="sortOrder" />
        <result column="occupant_id" property="occupantId" />
        <result column="occupant_type" property="occupantType" />
        <result column="status" property="status" />
        <result column="res_status" property="resStatus" />
        <result column="version" property="version" />
        <result column="del_flag" property="delFlag" />
    </resultMap>

    <select id="countRealOccupants" resultType="java.lang.Integer">
        SELECT COUNT(id) FROM dorm_bed
        WHERE room_id = #{roomId}
          AND occupant_id IS NOT NULL
          AND del_flag = '0'
    </select>

    <select id="selectBedIdsByGraduateGrade" resultType="java.lang.Long">
        SELECT b.id FROM dorm_bed b
                             INNER JOIN sys_ordinary_user u ON b.occupant_id = u.id
        WHERE u.enrollment_year = #{grade}
          AND u.user_category = 0  AND b.del_flag = '0'
    </select>

    <select id="findEmptyBedsInRoom" resultMap="BaseResultMap">
        SELECT * FROM dorm_bed
        WHERE room_id = #{roomId}
          AND status = 20
          AND res_status = 21
          AND occupant_id IS NULL
          AND del_flag = '0'
        ORDER BY sort_order ASC
    </select>
</mapper>